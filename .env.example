# ==========================================
# Krusch DBOS MCP Environment Configuration
# ==========================================

# ------------------------------------------
# Database Configuration
# ------------------------------------------
# The PostgreSQL connection string. Must include credentials and database name.
# Default (Docker): postgres://kruschdb:password@localhost:5432/kruschdb
DATABASE_URL=postgres://kruschdb:password@localhost:5432/kruschdb

# ------------------------------------------
# Web Server & UI Configuration
# ------------------------------------------
# Port for the Vite development server and backend API
PORT=5733
# Host binding for the web server
HOST=localhost
# The absolute HTTP URL for API routes (useful for reverse proxies/tunnels)
VITE_HTTP_URL=http://localhost:5733
# The absolute WebSockets URL for realtime DBOS orchestration
VITE_WS_URL=ws://localhost:5733

# ------------------------------------------
# AI Provider Configuration
# ------------------------------------------
# API Key for Google Gemini integrations (gemini-3.1-pro default)
GEMINI_API_KEY=your_gemini_api_key_here

# API Key for Anthropic Claude integrations (Claude 3.5 Sonnet / Opus)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# API Key for OpenAI or compatible endpoints (Codex / GPT-4o)
OPENAI_API_KEY=your_openai_api_key_here

# External Headless Agent URLs
EXTERNAL_AGENT_URL=http://localhost:11440/api/stream
OPENCLAW_AGENT_URL=http://localhost:5440/api/stream
HERMES_AGENT_URL=http://localhost:5442/api/stream

# Local URL for Ollama embeddings (used by VectorEmbeddingWorker)
# Default: http://localhost:11434/api/embeddings
OLLAMA_URL=http://localhost:11434/api/embeddings

# ------------------------------------------
# Desktop Thin-Client Configuration
# ------------------------------------------
# Directory for Krusch DBOS MCP local state (defaults to ~/.kd)
KD_HOME=~/.kd
# Provide a remote DBOS backend address when running the desktop app as a thin client
VITE_DEV_SERVER_URL=http://localhost:5733
# Set to '1' to disable automatic Electron updates
KD_DISABLE_AUTO_UPDATE=0

# Disable checkpoints when running natively on huge monorepos
KD_DISABLE_CHECKPOINTS=true
