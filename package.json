{
  "name": "@kruschdev/krusch-dbos-mcp",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*",
      "scripts"
    ],
    "catalog": {
      "effect": "4.0.0-beta.45",
      "@effect/atom-react": "4.0.0-beta.45",
      "@effect/openapi-generator": "4.0.0-beta.45",
      "@effect/platform-bun": "4.0.0-beta.45",
      "@effect/platform-node": "4.0.0-beta.45",
      "@effect/platform-node-shared": "4.0.0-beta.45",
      "@effect/sql-pg": "4.0.0-beta.45",
      "@effect/vitest": "4.0.0-beta.45",
      "@effect/language-service": "0.84.2",
      "@types/bun": "^1.3.11",
      "@types/node": "^24.10.13",
      "tsdown": "^0.20.3",
      "typescript": "^5.7.3",
      "vitest": "^4.0.0"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "bun scripts/dev-runner.ts dev",
    "dev:server": "bun scripts/dev-runner.ts dev:server",
    "start": "turbo run start --filter=t3",
    "start:mock-update-server": "node scripts/mock-update-server.ts",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "oxlint --report-unused-disable-directives",
    "test": "turbo run test",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "build:contracts": "turbo run build --filter=@t3tools/contracts",
    "release:smoke": "node scripts/release-smoke.ts",
    "clean": "rm -rf node_modules apps/*/node_modules packages/*/node_modules apps/*/dist packages/*/dist .turbo apps/*/.turbo packages/*/.turbo",
    "sync:vscode-icons": "node scripts/sync-vscode-icons.mjs"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "oxfmt": "^0.40.0",
    "oxlint": "^1.55.0",
    "playwright": "^1.59.1",
    "turbo": "^2.3.3",
    "vitest": "catalog:"
  },
  "overrides": {
    "@effect/atom-react": "catalog:",
    "@effect/platform-bun": "catalog:",
    "@effect/platform-node": "catalog:",
    "@effect/platform-node-shared": "catalog:",
    "@effect/sql-pg": "catalog:",
    "@effect/vitest": "catalog:",
    "effect": "catalog:"
  },
  "engines": {
    "bun": "^1.3.11",
    "node": "^24.13.1"
  },
  "packageManager": "bun@1.3.11",
  "msw": {
    "workerDirectory": [
      "apps/web/public"
    ]
  },
  "trustedDependencies": [
    "node-pty"
  ]
}
